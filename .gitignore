# =============================================================================
# BrickWorkPro 2.0 — keep source, config, and scripts; ignore build/local noise
# =============================================================================

# --- Environment & secrets ---
.env
.env.*
!.env.example
scripts/login.json
scripts/*-credentials*.json

# --- Backend (Java / Maven) ---
**/target/
**/build/
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

HELP.md
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# Maven wrapper JAR is downloaded locally; scripts are committed
**/.mvn/wrapper/maven-wrapper.jar

# --- Frontend (Angular / Node) ---
**/node_modules/
**/dist/
**/.angular/cache/
**/tmp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tsbuildinfo

# --- Logs & runtime output ---
*.log
*.log.*
scripts/logs/
scripts/**/*.png
!BrickWorkPro-2.0-Frontend/public/**/*.png

# --- IDEs & editors ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
!BrickWorkPro-2.0-Frontend/.vscode/
!BrickWorkPro-2.0-Frontend/.vscode/**
.cursor/

# Keep shared IntelliJ run configs for the backend
!BrickWorkPro-2.0-Backend/.run/
!BrickWorkPro-2.0-Backend/.run/**

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Test / coverage ---
coverage/
.nyc_output/
test-results/
playwright-report/

# --- Local AI / agent tooling (not part of the app) ---
agent-tools/
terminals/
mcps/
updates.jsonl

# --- NetBeans (legacy) ---
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# --- Explicit keeps (do not ignore) ---
!BrickWorkPro-2.0-Frontend/.postcssrc.json
!BrickWorkPro-2.0-Frontend/tailwind.config.js