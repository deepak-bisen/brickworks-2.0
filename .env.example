# BrickWorkPro 2.0 - Environment Variables
# Copy to .env and fill in real values for local/production use.

# Database (all services)
DB_USERNAME=root
DB_PASSWORD=root

# JWT (must match across users, orders, products, finance)
# Min 32 bytes for HS256 — use: openssl rand -base64 32
JWT_SECRET=change-me-use-openssl-rand-base64-32-in-production
JWT_EXPIRATION=86400000

# Internal service-to-service authentication
INTERNAL_SERVICE_KEY=change-me

# Razorpay (finance service)
RAZORPAY_KEY_ID=change-me
RAZORPAY_KEY_SECRET=change-me
RAZORPAY_WEBHOOK_SECRET=change-me

# Email / SMTP (orders service)
MAIL_USERNAME=change-me
MAIL_PASSWORD=change-me

# WhatsApp / UltraMsg (orders service)
WHATSAPP_INSTANCE_ID=change-me
WHATSAPP_TOKEN=change-me